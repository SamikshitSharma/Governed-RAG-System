{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "7618365547685796848"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "openAiApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "OpenAI API key stored in Key Vault and exposed to the API container."
      }
    },
    "anthropicApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "Anthropic API key stored in Key Vault and exposed to the API container."
      }
    },
    "containerAppEnvironmentName": {
      "type": "string",
      "defaultValue": "rag-env",
      "metadata": {
        "description": "Container Apps environment name."
      }
    },
    "apiContainerAppName": {
      "type": "string",
      "defaultValue": "rag-api",
      "metadata": {
        "description": "API Container App name."
      }
    },
    "uiContainerAppName": {
      "type": "string",
      "defaultValue": "rag-ui",
      "metadata": {
        "description": "UI Container App name."
      }
    },
    "acrName": {
      "type": "string",
      "defaultValue": "ragacrmilug0430",
      "metadata": {
        "description": "Azure Container Registry name."
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "rag-kv-milug-0430",
      "metadata": {
        "description": "Azure Key Vault name."
      }
    },
    "storageShareName": {
      "type": "string",
      "defaultValue": "chroma-data",
      "metadata": {
        "description": "Azure Files share name used for Chroma persistence."
      }
    },
    "storageAccountName": {
      "type": "string",
      "defaultValue": "[toLower(format('rag{0}', uniqueString(resourceGroup().id)))]",
      "metadata": {
        "description": "Storage account name for Azure Files."
      }
    },
    "apiImage": {
      "type": "string",
      "defaultValue": "[format('{0}.azurecr.io/rag-api:latest', parameters('acrName'))]",
      "metadata": {
        "description": "API image reference. The deploy script updates this to the freshly built ACR image."
      }
    },
    "uiImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Placeholder UI image."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "rag-law",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[parameters('acrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "adminUserEnabled": false
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "properties": {
        "accessTier": "Hot",
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', parameters('storageAccountName'), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', parameters('storageAccountName'), 'default', parameters('storageShareName'))]",
      "properties": {
        "enabledProtocols": "SMB",
        "shareQuota": 100
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices', parameters('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "rag-app-identity",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "tenantId": "[subscription().tenantId]",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "accessPolicies": [
          {
            "tenantId": "[subscription().tenantId]",
            "objectId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', 'rag-app-identity'), '2023-01-31').principalId]",
            "permissions": {
              "secrets": [
                "Get",
                "List"
              ]
            }
          }
        ],
        "enableRbacAuthorization": false,
        "enabledForTemplateDeployment": true,
        "enabledForDeployment": true,
        "enabledForDiskEncryption": false,
        "publicNetworkAccess": "Enabled",
        "softDeleteRetentionInDays": 7
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', 'rag-app-identity')]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'OPENAI-API-KEY')]",
      "properties": {
        "value": "[parameters('openAiApiKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'ANTHROPIC-API-KEY')]",
      "properties": {
        "value": "[parameters('anthropicApiKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerAppEnvironmentName')]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', 'rag-law'), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', 'rag-law'), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', 'rag-law')]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments/storages",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', parameters('containerAppEnvironmentName'), parameters('storageShareName'))]",
      "properties": {
        "azureFile": {
          "accessMode": "ReadWrite",
          "accountName": "[parameters('storageAccountName')]",
          "accountKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2023-05-01').keys[0].value]",
          "shareName": "[parameters('storageShareName')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvironmentName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[parameters('apiContainerAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', 'rag-app-identity'))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 8000,
            "transport": "auto",
            "allowInsecure": false
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').loginServer]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', 'rag-app-identity')]"
            }
          ],
          "secrets": [
            {
              "name": "openai-api-key",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', 'rag-app-identity')]",
              "keyVaultUrl": "[format('{0}secrets/OPENAI-API-KEY', reference(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), '2023-07-01').vaultUri)]"
            },
            {
              "name": "anthropic-api-key",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', 'rag-app-identity')]",
              "keyVaultUrl": "[format('{0}secrets/ANTHROPIC-API-KEY', reference(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), '2023-07-01').vaultUri)]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "rag-api",
              "image": "[parameters('apiImage')]",
              "env": [
                {
                  "name": "OPENAI_API_KEY",
                  "secretRef": "openai-api-key"
                },
                {
                  "name": "ANTHROPIC_API_KEY",
                  "secretRef": "anthropic-api-key"
                },
                {
                  "name": "CHROMA_PATH",
                  "value": "/mnt/chroma"
                }
              ],
              "resources": {
                "cpu": "0.5",
                "memory": "1Gi"
              },
              "volumeMounts": [
                {
                  "volumeName": "chroma-data",
                  "mountPath": "/mnt/chroma"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 1
          },
          "volumes": [
            {
              "name": "chroma-data",
              "storageType": "AzureFile",
              "storageName": "[parameters('storageShareName')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), 'ANTHROPIC-API-KEY')]",
        "[resourceId('Microsoft.App/managedEnvironments/storages', parameters('containerAppEnvironmentName'), parameters('storageShareName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', 'rag-app-identity')]",
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), 'OPENAI-API-KEY')]",
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvironmentName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[parameters('uiContainerAppName')]",
      "location": "[parameters('location')]",
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 3000,
            "transport": "auto",
            "allowInsecure": false
          }
        },
        "template": {
          "containers": [
            {
              "name": "rag-ui",
              "image": "[parameters('uiImage')]",
              "resources": {
                "cpu": "0.25",
                "memory": "0.5Gi"
              }
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 1
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvironmentName'))]"
      ]
    }
  ],
  "outputs": {
    "apiUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', parameters('apiContainerAppName')), '2023-05-01').configuration.ingress.fqdn)]"
    },
    "uiUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', parameters('uiContainerAppName')), '2023-05-01').configuration.ingress.fqdn)]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').loginServer]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), '2023-07-01').vaultUri]"
    }
  }
}